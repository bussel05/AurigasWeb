---
const CHANNEL_VIDEOS_URL = "https://www.youtube.com/@AurigasArchive/videos";
const RSS_FEED = "https://www.youtube.com/feeds/videos.xml?channel_id=UC1B0iXsRUVHFit6dvwnBDlw";
const YOUTUBE_ICON_PATH = "M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z";

let videos: { id: string; title: string; thumbnail: string; url: string }[] = [];

try {
  const res = await fetch(RSS_FEED);
  const xml = await res.text();

  const entries = [...xml.matchAll(/<entry>([\s\S]*?)<\/entry>/g)];
  videos = entries.map((entry) => {
    const content = entry[1];
    const id = (content.match(/<yt:videoId>(.*?)<\/yt:videoId>/) || [])[1] || "";
    const title = (content.match(/<title>(.*?)<\/title>/) || [])[1] || "";
    const thumbnail = `https://i.ytimg.com/vi/${id}/hqdefault.jpg`;
    const url = `https://www.youtube.com/watch?v=${id}`;
    return { id, title: title.replace(/&amp;/g, "&").replace(/&lt;/g, "<").replace(/&gt;/g, ">").replace(/&#39;/g, "'").replace(/&quot;/g, '"'), thumbnail, url };
  });
} catch (e) {
  console.error("Failed to fetch YouTube RSS feed", e);
}
---

<section class="yt-section container mx-auto px-8 md:px-20 pt-8">
  <header class="mb-10 text-center flex flex-col items-center ">
      <div class="flex flex-row">
        <h2 class="text-2xl md:text-4xl lg:text-5xl  font-bold text-white drop-shadow-lg group-hover:text-red-400 transition-colors duration-300">
          Streams Archive
        </h2>
        <img src="/images/emotes/auri-backup.webp" alt="YouTube Icon" class="md:w-15 md:h-15 w-10 h-10" />
      </div>
    <p class="text-base md:text-lg text-white/60 ">
      Mira los últimos streams de Aurigas
    </p>
  </header>

  {videos.length === 0 ? (
    <div class="text-center text-white/40 py-20">
      <svg class="mx-auto mb-4 opacity-30" viewBox="0 0 24 24" fill="currentColor" width="64" height="64">
        <path d={YOUTUBE_ICON_PATH}/>
      </svg>
      <p>No se pudieron cargar los streams.</p>
    </div>
  ) : (
    <div class="videos-grid">
      {videos.map((video) => (
        <a
          href={video.url}
          target="_blank"
          rel="noopener noreferrer"
          class="video-card bg-[#0a1224] rounded-md overflow-hidden shadow-lg hover:scale-105 transition-transform duration-300 group"
        >
            <div class="relative overflow-hidden aspect-video bg-[#121a2e]">
            <img
                src={video.thumbnail}
                alt={video.title}
                width="480"
                height="360"
                class="w-full h-full object-cover group-hover:brightness-110 transition-all duration-300"
                loading="lazy"
                decoding="async"
            />
          </div>
          <div class="p-3">
            <h3 class="text-xs font-semibold text-white leading-snug line-clamp-2 group-hover:text-blue-500 transition-colors duration-200">
              {video.title}
            </h3>
          </div>
        </a>
      ))}
    </div>
    <a
    href={CHANNEL_VIDEOS_URL}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center justify-center mt-8 px-5 py-2 rounded-md bg-[#121a2e] hover:bg-blue-900/80 border border-white/10 text-white/90 hover:text-white text-sm font-medium backdrop-blur-sm transition-all duration-300"
  >
    Ver todos los streams</a>
  )}
</section>

<style>
  .yt-section {
    font-family: inherit;
  }

  .yt-channel-link {
    text-decoration: none;
  }

  .yt-icon {
    color: #ff0000;
    filter: drop-shadow(0 0 8px rgba(255, 0, 0, 0.4));
  }

  .videos-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1rem;
  }

  @media (max-width: 1024px) {
    .videos-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 640px) {
    .videos-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>