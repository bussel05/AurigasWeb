<section class="flex-1 flex flex-col justify-center container mx-auto px-4" id="project-detail">
  <p class="text-white/50 text-center">Cargando proyecto...</p>
</section>

<script>
  import { projects } from '../data/projects.ts';

  const el = document.getElementById('project-detail');

  function renderDetail(slug) {
    const project = projects.find(p => p.slug === slug) ?? projects[0];

    const galleryHTML = project.gallery?.length
      ? `<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 pt-8">
          ${project.gallery.map(src => `
            <img src="${src}" class="rounded-lg w-full h-45 object-cover" />
          `).join('')}
        </div>`
      : '';

    const youtubeBtn = project.youtubeUrl
      ? `<a href="${project.youtubeUrl}" target="_blank" rel="noopener noreferrer" 
            class="w-full sm:w-auto justify-center px-4 py-2 rounded-md hover:bg-red-700/80 border cursor-pointer border-white/10 text-white/90 hover:text-white text-sm font-medium backdrop-blur-sm transition-all duration-300 flex items-center gap-2">
            <i class="fa-brands fa-youtube text-white text-2xl"></i>
            VER EPISODIO
          </a>`
      : '';

    const archiveBtn = project.archiveUrl
      ? `<a href="${project.archiveUrl}" target="_blank" rel="noopener noreferrer" 
            class="w-full sm:w-auto justify-center px-4 py-2 rounded-md hover:bg-blue-700/80 border cursor-pointer border-white/10 text-white/90 hover:text-white text-sm font-medium backdrop-blur-sm transition-all duration-300 flex items-center gap-2">
            <i class="fa-solid fa-box-archive text-white text-2xl"></i>
            ARCHIVE
          </a>`
      : '';

    const endText = project.end ?? 'En curso';

    const durationHTML = project.duration
      ? `<span class="flex flex-row items-center font-normal text-sm sm:text-lg">
           <h4 class="font-bold pr-2">Duración:</h4>${project.duration}
         </span>`
      : '';

    el.innerHTML = `
      <header class="my-6 text-center flex flex-col items-center">
        <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-white drop-shadow-lg">
          ${project.name.toUpperCase()}
        </h2>
        <p class="text-sm sm:text-base md:text-lg text-white/60 mt-2">
          ${project.start} → ${endText}
        </p>
      </header>

      <main class="space-y-10">
        <section>
          <div class="flex flex-col md:flex-row gap-6 md:gap-10 items-start">
            <img
              src="${project.mainImage}"
              alt="${project.name}"
              class="rounded-lg w-full md:w-[460px] h-auto object-cover"
            />
            <div class="flex flex-col w-full">
              <p class="w-full max-w-3xl text-white/80 text-sm sm:text-base leading-relaxed">
                ${project.description}
              </p>
              <div class="flex flex-col sm:flex-row gap-2 sm:gap-4 pt-4 text-white/90">
                ${durationHTML}
                <span class="flex flex-row items-center font-normal text-sm sm:text-lg">
                  <h4 class="font-bold pr-2">Versión:</h4>${project.version}
                </span>
              </div>
              <div class="flex flex-col sm:flex-row gap-3 pt-5">
                ${youtubeBtn}
                ${archiveBtn}
              </div>
            </div>
          </div>
          ${galleryHTML}
        </section>
      </main>
    `;
  }

  renderDetail(new URLSearchParams(window.location.search).get('project'));

  window.addEventListener('project-change', (e) => {
    renderDetail(e.detail.slug);
  });

  window.addEventListener('popstate', (e) => {
    const slug = e.state?.project ?? new URLSearchParams(window.location.search).get('project');
    renderDetail(slug);
  });
</script>