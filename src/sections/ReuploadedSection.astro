---
const CHANNEL_VIDEOS_URL = "https://www.youtube.com/@AurigasArchive/videos";
const RSS_FEED = "https://www.youtube.com/feeds/videos.xml?channel_id=UC1B0iXsRUVHFit6dvwnBDlw";

const YOUTUBE_ICON_PATH = "M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z";
---

<section class="yt-section flex-1 flex flex-col justify-center container mx-auto px-8 md:px-20 pt-8">
  <header class="mb-10 text-center flex flex-col items-center">
    <div class="flex flex-row items-center gap-2">
      <h2
        class="text-2xl md:text-4xl lg:text-5xl font-bold text-white drop-shadow-lg"
      >
        Streams Archive
      </h2>

      <img
        src="/images/emotes/auri-backup.webp"
        alt="Aurigas"
        class="md:w-15 md:h-15 w-10 h-10"
      />
    </div>

    <p class="text-base md:text-lg text-white/60 mt-1">
      Mira los últimos streams de Aurigas
    </p>
  </header>

  <div id="videos-container" class="videos-grid">
    <div class="text-center text-white/40 py-20 col-span-full">
      <svg
        class="mx-auto mb-4 opacity-30"
        viewBox="0 0 24 24"
        fill="currentColor"
        width="64"
        height="64"
      >
        <path d={YOUTUBE_ICON_PATH}></path>
      </svg>

      <p>Cargando streams...</p>
    </div>
  </div>

  <div class="flex justify-center mt-10">
    <a
      href={CHANNEL_VIDEOS_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="ver-todos-btn"
    >
      Ver todos los streams
    </a>
  </div>
</section>

<script define:vars={{ RSS_FEED }}>
  function showError(container, msg) {
    container.innerHTML = `
      <div class="text-center text-white/40 py-20 col-span-full">
        <p>${msg}</p>
      </div>
    `;
  }

  function createVideoCard(video) {
    const a = document.createElement("a");

    a.href = video.url;
    a.target = "_blank";
    a.rel = "noopener noreferrer";
    a.className = "video-card";

    a.innerHTML = `
      <div class="img-wrapper">
        <img
          src="https://i.ytimg.com/vi/${video.id}/mqdefault.jpg"
          alt="${video.title}"
          loading="lazy"
          decoding="async"
        />
      </div>

      <div class="info">
        <h3 class="video-title">${video.title}</h3>
      </div>
    `;

    const img = a.querySelector("img");

    img.onerror = () => {
      img.src = `https://i.ytimg.com/vi/${video.id}/default.jpg`;
    };

    return a;
  }

  async function loadVideos() {
    const container = document.getElementById("videos-container");

    if (!container) return;

    try {
      const proxy =
        `https://corsproxy.io/?url=${encodeURIComponent(RSS_FEED)}`;

      const res = await fetch(proxy, {
        cache: "no-store",
      });

      if (!res.ok) {
        throw new Error(`HTTP ${res.status}`);
      }

      const xmlText = await res.text();

      const parser = new DOMParser();

      const xml = parser.parseFromString(xmlText, "text/xml");

      const entries = [...xml.querySelectorAll("entry")];

      if (!entries.length) {
        showError(container, "No se pudieron cargar los streams.");
        return;
      }

      const videos = entries.slice(0, 15).map((entry) => {
        const link =
          entry.querySelector("link")?.getAttribute("href") ?? "";

        const id =
          new URL(link).searchParams.get("v") ?? "";

        const title =
          entry.querySelector("title")?.textContent ?? "Video";

        return {
          id,
          title,
          url: link,
        };
      });

      container.innerHTML = "";

      videos.forEach((video) => {
        container.appendChild(createVideoCard(video));
      });

    } catch (err) {
      console.error(err);

      showError(container, "Error cargando streams.");
    }
  }

  loadVideos();
</script>

<style is:global>
  .yt-section {
    position: relative;
    font-family: inherit;
  }

  .videos-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 1rem;
  }

  @media (max-width: 1200px) {
    .videos-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media (max-width: 1024px) {
    .videos-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .videos-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.8rem;
    }
  }

  .video-card {
    position: relative;

    display: flex;
    flex-direction: column;

    overflow: hidden;

    border-radius: 8px;

    background:
      linear-gradient(
        180deg,
        rgba(18, 24, 38, 0.96) 0%,
        rgba(10, 14, 24, 0.98) 100%
      );

    border: 1px solid rgba(255, 255, 255, 0.06);

    text-decoration: none;

    transition:
      transform 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease;

    box-shadow:
      0 10px 30px rgba(0, 0, 0, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.03);

    backdrop-filter: blur(10px);
  }

  .video-card:hover {
    transform: translateY(-5px);

    border-color: rgba(96, 165, 250, 0.35);

    box-shadow:
      0 18px 40px rgba(0, 0, 0, 0.45),
      0 0 20px rgba(59, 130, 246, 0.18);
  }

  .img-wrapper {
    position: relative;

    width: 100%;

    aspect-ratio: 16 / 9;

    overflow: hidden;

    background: #111827;
  }

  .img-wrapper::after {
    content: "";

    position: absolute;
    inset: 0;

    background:
      linear-gradient(
        to top,
        rgba(0, 0, 0, 0.5),
        transparent 50%
      );
  }

  .img-wrapper img {
    width: 100%;
    height: 100%;

    object-fit: cover;

    transition:
      transform 0.4s ease,
      filter 0.4s ease;
  }

  .video-card:hover .img-wrapper img {
    transform: scale(1.05);
    filter: brightness(1.08);
  }

  .info {
    padding: 0.9rem 1rem 1rem;
  }

  .video-title {
    margin: 0;

    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.45;

    color: rgba(255, 255, 255, 0.96);

    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;

    overflow: hidden;

    transition: color 0.25s ease;
  }

  .video-card:hover .video-title {
    color: #93c5fd;
  }

  .ver-todos-btn {
    position: relative;

    overflow: hidden;

    display: inline-flex;
    align-items: center;
    justify-content: center;

    padding: 10px 20px;

    border-radius: 10px;

    background:
      linear-gradient(
        135deg,
        rgba(7, 63, 183, 0.95),
        rgba(5, 57, 141, 0.9)
      );

    border: 1px solid rgba(147, 197, 253, 0.2);

    color: white;

    text-decoration: none;

    font-size: 0.92rem;
    font-weight: 600;

    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease;
  }

  .ver-todos-btn:hover {
    transform: translateY(-2px);

    box-shadow:
      0 16px 35px rgba(37, 99, 235, 0.35),
      0 0 20px rgba(96, 165, 250, 0.2);
  }

  @media (max-width: 640px) {
    .video-title {
      font-size: 0.82rem;
    }

    .info {
      padding: 0.8rem;
    }

    .ver-todos-btn {
      width: 100%;
      max-width: 320px;
    }
  }
</style>