---
const CHANNEL_VIDEOS_URL = "https://www.youtube.com/@AurigasArchive/videos";

const RSS_FEED =
  "https://www.youtube.com/feeds/videos.xml?channel_id=UC1B0iXsRUVHFit6dvwnBDlw";

const YOUTUBE_ICON_PATH =
  "M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z";
---

<section class="yt-section container mx-auto px-8 md:px-20 pt-8">
  <header class="mb-10 text-center flex flex-col items-center">
    <div class="flex flex-row items-center">
      <h2
        class="text-2xl md:text-4xl lg:text-5xl font-bold text-white drop-shadow-lg"
      >
        Streams Archive
      </h2>

      <img
        src="/images/emotes/auri-backup.webp"
        alt="YouTube Icon"
        class="md:w-15 md:h-15 w-10 h-10"
      />
    </div>

    <p class="text-base md:text-lg text-white/60">
      Mira los últimos streams de Aurigas
    </p>
  </header>

  <div id="videos-container" class="videos-grid">
    <div class="text-center text-white/40 py-20 col-span-full">
      <svg
        class="mx-auto mb-4 opacity-30"
        viewBox="0 0 24 24"
        fill="currentColor"
        width="64"
        height="64"
      >
        <path d={YOUTUBE_ICON_PATH}></path>
      </svg>

      <p>Cargando streams...</p>
    </div>
  </div>

  <div class="flex justify-center">
    <a
      href={CHANNEL_VIDEOS_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center justify-center mt-8 px-5 py-2 rounded-md bg-[#121a2e] hover:bg-blue-900/80 border border-white/10 text-white/90 hover:text-white text-sm font-medium backdrop-blur-sm transition-all duration-300"
    >
      Ver todos los streams
    </a>
  </div>
</section>

<script define:vars={{ RSS_FEED }}>
  async function loadVideos() {
    const container = document.getElementById("videos-container");

    if (!container) return;

    try {
      const res = await fetch(
        `https://api.rss2json.com/v1/api.json?rss_url=${encodeURIComponent(
          RSS_FEED
        )}`,
        {
          cache: "no-store",
        }
      );

      const data = await res.json();

      if (!data.items?.length) {
        container.innerHTML = `
          <div class="text-center text-white/40 py-20 col-span-full">
            <p>No se pudieron cargar los streams.</p>
          </div>
        `;

        return;
      }

      const videos = data.items.map((video) => {
        const videoId = video.link.split("v=")[1];

        return {
          id: videoId,
          title: video.title,
          thumbnail: `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg`,
          url: video.link,
        };
      });

      container.innerHTML = videos
        .slice(0, 10)
        .map(
          (video) => `
            <a
              href="${video.url}"
              target="_blank"
              rel="noopener noreferrer"
              class="video-card bg-[#0a1224] rounded-md overflow-hidden shadow-lg hover:scale-105 transition-transform duration-300 group"
            >
              <div class="relative overflow-hidden aspect-video bg-[#121a2e]">
                <img
                  src="${video.thumbnail}"
                  alt="${video.title}"
                  class="w-full h-full object-cover group-hover:brightness-110 transition-all duration-300"
                  loading="lazy"
                  decoding="async"
                />
              </div>

              <div class="p-3">
                <h3 class="text-xs font-semibold text-white leading-snug line-clamp-2 group-hover:text-blue-500 transition-colors duration-200">
                  ${video.title}
                </h3>
              </div>
            </a>
          `
        )
        .join("");
    } catch (e) {
      console.error("Failed to load videos", e);

      container.innerHTML = `
        <div class="text-center text-white/40 py-20 col-span-full">
          <p>Error cargando streams.</p>
        </div>
      `;
    }
  }

  loadVideos();
</script>

<style>
  .yt-section {
    font-family: inherit;
  }

  .videos-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1rem;
  }

  @media (max-width: 1024px) {
    .videos-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 640px) {
    .videos-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>